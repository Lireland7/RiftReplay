{
  "name": "riftreplay",
  "version": "0.1.5",
  "description": "Deck tracker overlay for Riftbound on tcg-arena.fr",
  "author": "RiftReplay",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.riftreplay.app",
    "productName": "RiftReplay",
    "files": [
      "src/**/*",
      "overlay/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Lireland7",
      "repo": "RiftReplay"
    },
    "win": {
      "target": ["portable"]
    },
    "portable": {
      "artifactName": "RiftReplay-${version}-portable.exe"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
